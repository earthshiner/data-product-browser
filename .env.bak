# Teradata host and username — safe to store here (not sensitive)
TD_HOST=your-teradata-host
TD_USER=your-username

# DO NOT store TD_PASSWORD here.
# Store it in the system keyring instead:
#
#   uv run data-product-browser store-password
#
# Or export it for the current shell session only (never written to disk):
#
#   $env:TD_PASSWORD = "your-password"   # PowerShell
#   export TD_PASSWORD="your-password"   # bash
